rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Work orders - public read (for client tracking), auth write
    match /workOrders/{orderId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Store products - public read (for homepage), auth write
    match /storeProducts/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Store parts - public read (for homepage), auth write
    match /storeParts/{partId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Buyers - can read/write own data
    match /buyers/{buyerId} {
      allow read, write: if request.auth != null && request.auth.uid == buyerId;
    }

    // Everything else - authenticated users only
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
