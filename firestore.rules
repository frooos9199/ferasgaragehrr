rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if user is authenticated staff (admin or technician)
    function isStaff() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Users collection - admin only write, staff can read
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() || request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    // Buyers collection - public create (register), own read/update
    match /buyers/{buyerId} {
      allow read: if request.auth != null && (request.auth.uid == buyerId || isStaff());
      allow create: if request.auth != null && request.auth.uid == buyerId;
      allow update: if request.auth != null && request.auth.uid == buyerId;
      allow delete: if isAdmin();
    }

    // Work Orders - public read (client tracking), staff write
    match /workOrders/{orderId} {
      allow read: if true;
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Customers - staff read/write, admin delete
    match /customers/{customerId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Cars - staff read/write, admin delete
    match /cars/{carId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Invoices - staff read/write, admin delete
    match /invoices/{invoiceId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Inventory - staff read/write, admin delete
    match /inventory/{itemId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Store Products & Parts - public read, admin write
    match /storeProducts/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /storeParts/{partId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
